# ============================================================
# ZeroX Protocol — Root Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# ----- Blockchain -----
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_WS_URL=wss://avalanche-mainnet.infura.io/ws/v3/YOUR_KEY
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
FUJI_WS_URL=wss://avalanche-fuji.infura.io/ws/v3/YOUR_KEY
ALCHEMY_API_KEY=your_alchemy_api_key

# ----- Deployment -----
# Private key of the deployer wallet (for testnet only — use hardware wallet on mainnet)
DEPLOYER_PRIVATE_KEY=0x...

# Multisig signers (3-of-5)
MULTISIG_SIGNER_1=0x...
MULTISIG_SIGNER_2=0x...
MULTISIG_SIGNER_3=0x...
MULTISIG_SIGNER_4=0x...
MULTISIG_SIGNER_5=0x...

# ----- API Server -----
DATABASE_URL=postgresql://user:password@localhost:5432/zerox
REDIS_URL=redis://localhost:6379
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=change_me_in_production
ADMIN_SECRET=change_me_in_production

# ----- Fee Model -----
TREASURY_ADDRESS=0x...
FEE_RECIPIENT=0x...

# ----- Frontend -----
VITE_WC_PROJECT_ID=your_walletconnect_project_id
VITE_API_BASE_URL=http://localhost:3001
VITE_ALCHEMY_API_KEY=your_alchemy_api_key

# ----- Indexer -----
INDEXER_START_BLOCK=0

# ----- Chain -----
CHAIN_ID=43113
AVALANCHE_RPC_HTTP=https://api.avax-test.network/ext/bc/C/rpc
VITE_CHAIN_ID=43113

# ----- Contract Addresses (filled after deployment) -----
VAULT_USDC_ADDRESS=0x...
VAULT_USDT_ADDRESS=0x...
CREDIT_ADDRESS=0x...
SCORE_ADDRESS=0x...
REGISTRY_ADDRESS=0x...

# ----- Monitoring -----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
GRAFANA_API_KEY=your_grafana_api_key

# ----- Snowtrace (for contract verification) -----
SNOWTRACE_API_KEY=your_snowtrace_api_key
