{
  "name": "@zerox/contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "test:fuzz": "forge test --match-path 'test/foundry/**' -v",
    "test:invariant": "forge test --match-path 'test/foundry/**invariant**' -v",
    "coverage": "hardhat coverage",
    "lint": "solhint 'contracts/**/*.sol'",
    "deploy:fuji": "hardhat run scripts/deploy/00_deploy_registry.ts --network fuji && hardhat run scripts/deploy/01_deploy_vault_usdc.ts --network fuji && hardhat run scripts/deploy/02_deploy_vault_usdt.ts --network fuji && hardhat run scripts/deploy/03_deploy_score.ts --network fuji && hardhat run scripts/deploy/04_deploy_credit.ts --network fuji && hardhat run scripts/deploy/05_wire_registry.ts --network fuji",
    "deploy:mainnet": "hardhat run scripts/deploy/00_deploy_registry.ts --network mainnet",
    "verify:fuji": "hardhat run scripts/utils/verify.ts --network fuji",
    "clean": "hardhat clean && forge clean"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "@chainlink/contracts": "^1.3.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-foundry": "^1.1.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@typechain/hardhat": "^9.1.0",
    "@typechain/ethers-v6": "^0.5.1",
    "hardhat": "^2.22.17",
    "hardhat-gas-reporter": "^2.2.2",
    "solidity-coverage": "^0.8.14",
    "solhint": "^5.0.5",
    "typechain": "^8.3.2",
    "ethers": "^6.13.5",
    "chai": "^4.5.0",
    "typescript": "^5.7.3",
    "ts-node": "^10.9.2",
    "@types/node": "^22.10.6",
    "dotenv": "^16.4.7"
  }
}
