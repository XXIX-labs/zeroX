{
  "name": "@zerox/credit-sdk",
  "version": "1.0.0",
  "description": "ZeroX Protocol SDK — on-chain reads and writes for vault, credit, and score modules",
  "license": "MIT",
  "type": "module",
  "main":   "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types":   "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build":  "tsup",
    "dev":    "tsup --watch",
    "lint":   "tsc --noEmit",
    "test":   "vitest run"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "tsup":        "^8.3.5",
    "typescript":  "^5.7.3",
    "@types/node": "^22.10.6",
    "viem":        "^2.21.0",
    "vitest":      "^2.1.8"
  }
}
